{
  "name": "@expsh13/md-live",
  "version": "0.1.0",
  "description": "Local live Markdown viewer and editor with table-of-contents navigation.",
  "type": "module",
  "bin": {
    "md-live": "./bin/md-live.ts"
  },
  "files": [
    "assets",
    "bin",
    "public",
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/md-live.ts",
    "check": "vp check",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "test": "vp test run",
    "typecheck": "vp check --no-fmt --no-lint"
  },
  "dependencies": {
    "markdown-it": "^14.2.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "markdown",
    "viewer",
    "editor",
    "local",
    "toc"
  ],
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "vite-plus": "^0.1.24"
  }
}
